###############################################################################
# config.example.env
# Plantilla de configuración para GitHub Actions runners en Proxmox (LXC)
# 
# INSTRUCCIONES:
# 1. Copiar este archivo a config.env
#    cp config.example.env config.env
# 2. Editar config.env con tus credenciales reales
# 3. NUNCA hacer commit de config.env con credenciales reales
###############################################################################

# ==============================================================================
# Configuración de SSH para automatización remota
# ==============================================================================

# Método de ejecución: "ssh" (remoto) o "local" (desde host Proxmox)
# Para automatización completa desde Windows, usar "ssh"
EXEC_MODE="ssh"

# Configuración de SSH al host de Proxmox
PROXMOX_SSH_USER="root"
PROXMOX_SSH_HOST="192.168.1.100"
PROXMOX_SSH_PORT="22"

# Autenticación SSH:
# Opción 1: Clave SSH (recomendado) - dejar vacío para clave por defecto (~/.ssh/id_rsa)
PROXMOX_SSH_KEY=""

# Opción 2: Password (requiere sshpass)
PROXMOX_SSH_PASSWORD=""

# ==============================================================================
# Configuración de Proxmox VE
# ==============================================================================

# Host/IP de Proxmox
PROXMOX_HOST="192.168.1.100"

# Puerto de la API de Proxmox (por defecto 8006)
PROXMOX_PORT="8006"

# Usuario de Proxmox con permisos de API
# Formato: usuario@realm (ej: root@pam, admin@pve)
PROXMOX_USER="root@pam"

# Contraseña del usuario de Proxmox
PROXMOX_PASSWORD="tu_password_aqui"

# Nombre del nodo de Proxmox
PROXMOX_NODE="pve"

# ==============================================================================
# Configuración de GitHub
# ==============================================================================

# Token de acceso personal de GitHub
# Necesario para registrar runners y gestionar la API
# Crear en: https://github.com/settings/tokens
# Permisos necesarios: repo, admin:org (si usas organizaciones)
GITHUB_TOKEN="ghp_tu_token_aqui"

# Versión del GitHub Actions runner a instalar
# Dejar vacío para usar la última versión
RUNNER_VERSION="2.311.0"

# ==============================================================================
# Configuración de Contenedores LXC
# ==============================================================================

# Template LXC para usar como base
# El script automáticamente añade "local:vztmpl/" si no se incluye
# Nombre del archivo tal cual está en /var/lib/vz/template/cache/
# Ejemplos comunes:
#   ubuntu-22.04-standard_22.04-1_amd64.tar.zst
#   ubuntu-24.04-standard_24.04-1_amd64.tar.zst
#   debian-12-standard_12.7-1_amd64.tar.zst
LXC_TEMPLATE="ubuntu-22.04-standard_22.04-1_amd64.tar.zst"

# Opcionalmente puedes incluir el storage completo:
# LXC_TEMPLATE="local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst"

# Almacenamiento donde se crearán los contenedores
# Ejemplos: local-lvm, local-zfs, nfs-storage
LXC_STORAGE="local-lvm"

# Memoria RAM para cada contenedor en MB (por defecto 4096)
LXC_MEMORY="4096"

# Número de CPUs para cada contenedor (por defecto 2)
LXC_CPUS="2"

# Tamaño de disco en GB para cada contenedor (por defecto 30)
LXC_DISK="30"

# Contenedor no privilegiado (1 = sí, recomendado por seguridad)
# Los contenedores no privilegiados son más seguros
LXC_UNPRIVILEGED="1"

# Habilitar nestificación (1 = sí, REQUERIDO para Docker)
# Permite ejecutar Docker dentro del contenedor LXC
LXC_NESTING="1"

# Habilitar keyctl (1 = sí, REQUERIDO para Docker)
# Necesario para ciertas operaciones de seguridad de Docker
LXC_KEYCTL="1"

# ==============================================================================
# Configuración de Docker Engine
# ==============================================================================

# Versión de Docker Engine a instalar
# Dejar vacío para usar la última versión disponible
DOCKER_VERSION=""

# Usuario dedicado para ejecutar el runner (por defecto: runner)
# Este usuario tendrá permisos de sudo y estará en el grupo docker
RUNNER_USER="runner"

# ==============================================================================
# Configuración de Red (Opcional)
# ==============================================================================

# Bridge de red para los contenedores (por defecto vmbr0)
# NETWORK_BRIDGE="vmbr0"

# Rango de IPs para asignar automáticamente
# IP_POOL_START="192.168.1.200"
# IP_POOL_END="192.168.1.250"
# GATEWAY="192.168.1.1"
# DNS="8.8.8.8,8.8.4.4"

# ==============================================================================
# Configuración de Logs
# ==============================================================================

# Nivel de log: DEBUG, INFO, WARN, ERROR
LOG_LEVEL="INFO"

# Directorio de logs (relativo al proyecto)
LOG_DIR="logs"
